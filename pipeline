pipeline {
    agent any
    options {
        skipStagesAfterUnstable()
    }
    stages {
    stage('PULL') {
            steps {
               git branch: 'main', url: 'https://github.com/jambhulkarcloudblitz-alt/CDEC-studentapp.git'
            }
    }
     stage('Build') {
    steps {
        sh '''
            export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
            export PATH=$JAVA_HOME/bin:$PATH

            cd backend
            mvn clean package -DskipTests
        '''
    }
}
        stage('Test'){
            steps {
                withSonarQubeEnv(installationName: 'sonarqube',credentialsId: 'new-secret') {             
              sh '''cd backend
                    mvn sonar:sonar -Dsonar.projectKey=student-01'''
            }
        }
   }
       stage ('Quality-Gate') {
            steps {
                timeout(10) {
                    waitForQualityGate abortPipeline: true, credentialsId: 'new-secret'
                }
        }
        }
        stage('Delivery') {
            steps {
                 sh 'aws s3 cp backend/target/student-registration-backend-0.0.1-SNAPSHOT.jar s3://demo-s3-bucket-782100/studentapp.jar'
            }
        }
    }
}
