pipeline {
    agent any
    options {
        skipStagesAfterUnstable()
    }
    stages {
    stage('PULL') {
            steps {
               git branch: 'main', url: 'https://github.com/jambhulkarcloudblitz-alt/CDEC-studentapp.git'
            }
    }
     stage('Build') {
    steps {
        sh '''
            export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
            export PATH=$JAVA_HOME/bin:$PATH

            cd backend
            mvn clean package -DskipTests
        '''
    }
}
        stage('Test'){
            steps {
                 withSonarQubeEnv( installationName: 'instance' credentialsId: 'd4f7dc06-cad3-4f2d-9ada-888a9c9fef88') {              
              sh '''cd backend
                    mvn sonar:sonar -Dsonar.projectKey=test-project'''
            }
        }
   }
       stage ('Quality-Gate') {
            steps {
                timeout(10) {
                    waitForQualityGate abortPipeline: true, credentialsId: 'd4f7dc06-cad3-4f2d-9ada-888a9c9fef88'
                }
        }
        }
        stage('Deploy') {
            steps {
                echo 'deploy success'
            }
        }
    }
}
